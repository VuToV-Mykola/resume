{
  "name": "bewerbung-stationsservice",
  "version": "1.0.0",
  "description": "Professional job application document generator optimized for modern recruiting systems 2025. Specifically configured for work at Universitätsklinikum Magdeburg.",
  "main": "index.html",
  "homepage": "https://vutov.github.io/bewerbung-stationsservice",
  "scripts": {
    "start": "python -m http.server 8000",
    "server": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run start\"",
    "build": "npm run build:css && echo 'Build complete'",
    "build:css": "postcss css/styles.css -o css/styles.min.css",
    "deploy": "npm run build && gh-pages -d .",
    "setup-libs": "node setup-libs.js",
    "postinstall": "npm run setup-libs",
    "lint": "eslint js/**/*.js --fix",
    "lint:check": "eslint js/**/*.js",
    "format": "prettier --write \"**/*.{js,css,html,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,md}\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "validate": "npm run lint:check && npm run format:check && npm run test"
  },
  "keywords": [
    "bewerbung",
    "lebenslauf",
    "cv",
    "resume",
    "job-application",
    "stationsservice",
    "magdeburg",
    "german",
    "ukrainian"
  ],
  "author": "Mykola Vutov",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^30.1.2",
    "cssnano": "^7.0.6",
    "eslint": "^9.35.0",
    "gh-pages": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "express": "^4.18.2",
    "html-docx-js": "^0.3.1",
    "translate-google": "^1.5.0"
  }
}

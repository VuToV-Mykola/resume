<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <!-- Документ/резюме фон -->
  <rect x="12" y="8" width="40" height="48" rx="2" fill="#1a5490"/>

  <!-- Білий фон документа -->
  <rect x="14" y="10" width="36" height="44" rx="1" fill="white"/>

  <!-- Лінії тексту -->
  <rect x="18" y="16" width="28" height="2" rx="1" fill="#1a5490" opacity="0.8"/>
  <rect x="18" y="22" width="20" height="2" rx="1" fill="#1a5490" opacity="0.6"/>
  <rect x="18" y="28" width="24" height="2" rx="1" fill="#1a5490" opacity="0.6"/>

  <!-- Розділювач -->
  <line x1="18" y1="35" x2="46" y2="35" stroke="#1a5490" stroke-width="1" opacity="0.3"/>

  <!-- Додаткові лінії -->
  <rect x="18" y="40" width="22" height="2" rx="1" fill="#1a5490" opacity="0.5"/>
  <rect x="18" y="46" width="18" height="2" rx="1" fill="#1a5490" opacity="0.5"/>

  <!-- Іконка галочки (підтвердження) -->
  <circle cx="44" cy="52" r="8" fill="#4CAF50"/>
  <path d="M40 52 L42 54 L48 48" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
</svg>